### Health Check
GET {{host}}/health

> {%
client.test("Request executed successfully", function() {
  client.assert(response.status === 200, "Response status is not 200");
});
%}

### Create a 'bet' transaction for User 1 (Decimal Amount)
POST {{host}}/transactions
Content-Type: application/json

{
  "user_id": 1,
  "transaction_type": "bet",
  "amount": 10.50,
  "timestamp": "2023-10-27T10:00:00Z"
}

### Create a 'win' transaction for User 1 (Integer Amount, Newer)
POST {{host}}/transactions
Content-Type: application/json

{
  "user_id": 1,
  "transaction_type": "win",
  "amount": 50,
  "timestamp": "2023-10-27T11:30:00Z"
}

### Create a 'bet' transaction for User 1 (Most Recent)
POST {{host}}/transactions
Content-Type: application/json

{
  "user_id": 1,
  "transaction_type": "bet",
  "amount": 25.75,
  "timestamp": "2023-10-27T12:00:00Z"
}

### Create a transaction WITHOUT timestamp (Should be saved with NULL)
POST {{host}}/transactions
Content-Type: application/json

{
  "user_id": 1,
  "transaction_type": "win",
  "amount": 300.99
}

### Get all transactions for User 1 (Sorted by timestamp DESC, NULLS LAST)
GET {{host}}/transactions?user_id=1
Accept: application/json

### Get only 'bet' transactions for User 1
GET {{host}}/transactions?user_id=1&transaction_type=bet
Accept: application/json


### Error cases testing

### Invalid User ID (Should return 400)
GET {{host}}/transactions?user_id=invalid
Accept: application/json

### Missing User ID (Should return 400)
GET {{host}}/transactions
Accept: application/json

### Invalid Transaction Type (Should return 400)
POST {{host}}/transactions
Content-Type: application/json

{
  "user_id": 1,
  "transaction_type": "bonus",
  "amount": 100
}

### Negative amount (Should return 400)
POST {{host}}/transactions
Content-Type: application/json

{
  "user_id": 1,
  "transaction_type": "bet",
  "amount": -5.50
}
